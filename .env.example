# Database
DATABASE_URL=postgresql://jaurnalist:jaurnalist@localhost:5432/jaurnalist

# Redis (optional - needed for BullMQ, omit for minimal self-hosted)
REDIS_URL=redis://localhost:6379

# Encryption key for API keys stored in DB (generate with: openssl rand -hex 32)
JAURNALIST_ENCRYPTION_KEY=

# Admin password for settings panel
JAURNALIST_ADMIN_PASSWORD=admin

# Federation (optional - connect to central platform)
JAURNALIST_CENTRAL_API_URL=
JAURNALIST_CENTRAL_API_TOKEN=

# AI Provider API Keys (also configurable via web settings)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
