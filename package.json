{
  "name": "jaurnalist",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "dotenv -e .env -- turbo db:generate --filter=@jaurnalist/db",
    "db:migrate": "dotenv -e .env -- turbo db:migrate --filter=@jaurnalist/db",
    "db:push": "dotenv -e .env -- turbo db:push --filter=@jaurnalist/db"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "postgres": "^3.4.8",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
